{
  "name": "agentcode",
  "version": "0.1.0",
  "description": "Terminal AI coding assistant prototype.",
  "type": "module",
  "bin": {
    "agentcode": "./dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome lint ./src ./tests",
    "format": "biome format --write ./src ./tests",
    "check": "biome check --write ./src ./tests",
    "test": "vitest --run",
    "test:run": "vitest --run",
    "test:watch": "vitest",
    "e2e:tmux": "npm run build && bash tests/e2e/tmux/agentcode-smoke.sh"
  },
  "dependencies": {
    "eventsource-parser": "^3.0.6",
    "ink": "^6.5.1",
    "picomatch": "^4.0.5",
    "react": "^19.2.3",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^25.0.2",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
